# Supabase — get these from Project Settings > API
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Prefect Cloud — get from app.prefect.io > Settings > API Keys
PREFECT_API_KEY=
PREFECT_API_URL=

# Email notifications via Resend (resend.com) — leave blank to disable
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev   # replace with your verified domain address
EMAIL_RECIPIENT=                   # destination address
